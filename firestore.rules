rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time
        && (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    function isValidWorkflow(data) {
       return data.keys().hasAll(['name', 'nodes', 'edges', 'ownerId'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.ownerId == request.auth.uid
        && data.nodes is list && data.nodes.size() <= 100
        && data.edges is list && data.edges.size() <= 200;
    }

    // Collection Rules

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
        && (incoming().get('displayName', null) == null || incoming().displayName is string)
        && (incoming().get('photoURL', null) == null || incoming().photoURL is string);
    }

    // Workflows Collection
    match /workflows/{workflowId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isEmailVerified() 
        && isValidId(workflowId)
        && isValidWorkflow(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isEmailVerified()
        && existing().ownerId == request.auth.uid
        && isValidWorkflow(incoming())
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().ownerId == existing().ownerId;

      allow delete: if isOwner(existing().ownerId);
    }
  }
}
