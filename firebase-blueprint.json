{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Workflow": {
      "title": "HR Workflow",
      "description": "Visual HR workflow definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "nodes": { "type": "array" },
        "edges": { "type": "array" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "nodes", "edges", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "Stored HR workflows"
    }
  }
}
